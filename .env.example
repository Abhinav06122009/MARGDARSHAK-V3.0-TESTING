# --- PUBLIC KEYS (Safe for Frontend) ---
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key

# --- PRIVATE KEYS (MUST NOT HAVE VITE_ PREFIX) ---
# Move these to Netlify/Supabase Environment Variables!
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
OPENAI_API_KEY=your_openai_api_key
CLERK_SECRET_KEY=your_clerk_secret_key
CLERK_WEBHOOK_SECRET=your_clerk_webhook_secret

# SECURITY SETTINGS
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com
CLERK_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
VITE_ID_SALT=mg_default_internal_salt_v1
ID_SALT=mg_default_internal_salt_v1
